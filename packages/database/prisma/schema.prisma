  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?        @map("deleted_at") @db.Timestamptz(6)
  createdBy       String?          @map("created_by") @db.Uuid
  updatedBy       String?          @map("updated_by") @db.Uuid
  version         Int              @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  account      CrmAccount?  @relation(fields: [accountId], references: [id])
  deals        Deal[]

  @@unique([organizationId, externalId], map: "uq_crm_contacts_org_external_id")
  @@index([organizationId], map: "idx_crm_contacts_organization_id")
  @@index([organizationId, accountId], map: "idx_crm_contacts_org_account_active")
  @@index([organizationId, ownerId], map: "idx_crm_contacts_org_owner_active")
  @@map("contacts")
  @@schema("customer")
}

model PipelineStage {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  pipelineId     String    @default(dbgenerated("gen_random_uuid()")) @map("pipeline_id") @db.Uuid
  pipelineName   String    @default("Default Pipeline") @map("pipeline_name")
  name           String
  description    String?
  sortOrder      Int       @map("sort_order")
  probability    Int       @default(0)
  isDefault      Boolean   @default(false) @map("is_default")
  isWon          Boolean   @default(false) @map("is_won")
  isLost         Boolean   @default(false) @map("is_lost")
  isClosed       Boolean   @default(false) @map("is_closed")
  color          String?
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?   @map("created_by") @db.Uuid
  updatedBy      String?   @map("updated_by") @db.Uuid
  version        Int       @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  deals        Deal[]

  @@unique([organizationId, pipelineId, sortOrder], map: "uq_pipeline_stages_org_pipeline_order")
  @@index([organizationId], map: "idx_pipeline_stages_organization_id")
  @@index([organizationId, pipelineId, sortOrder], map: "idx_pipeline_stages_org_pipeline_active")
  @@map("pipeline_stages")
  @@schema("customer")
}

model Deal {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String     @map("organization_id") @db.Uuid
  externalId        String?    @map("external_id")
  name              String
  accountId         String?    @map("account_id") @db.Uuid
  contactId         String?    @map("contact_id") @db.Uuid
  pipelineStageId   String     @map("pipeline_stage_id") @db.Uuid
  ownerId           String     @map("owner_id") @db.Uuid
  amount            Decimal    @default(0) @db.Decimal(19, 4)
  currencyCode      String     @default("USD") @map("currency_code") @db.Char(3)
  probability       Int        @default(0)
  expectedCloseDate DateTime?  @map("expected_close_date") @db.Date
  actualCloseDate   DateTime?  @map("actual_close_date") @db.Date
  status            DealStatus @default(open)
  lossReason        String?    @map("loss_reason")
  leadSource        String?    @map("lead_source")
  description       String?
  metadata          Json       @default("{}")
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?  @map("deleted_at") @db.Timestamptz(6)
  createdBy         String?    @map("created_by") @db.Uuid
  updatedBy         String?    @map("updated_by") @db.Uuid
  version           Int        @default(1)

  organization  Organization  @relation(fields: [organizationId], references: [id])
  account       CrmAccount?   @relation(fields: [accountId], references: [id])
  contact       CrmContact?   @relation(fields: [contactId], references: [id])
  pipelineStage PipelineStage @relation(fields: [pipelineStageId], references: [id])

  @@unique([organizationId, externalId], map: "uq_deals_org_external_id")
  @@index([organizationId], map: "idx_deals_organization_id")
  @@index([organizationId, pipelineStageId], map: "idx_deals_org_stage_active")
  @@index([organizationId, ownerId], map: "idx_deals_org_owner_active")
  @@index([organizationId, accountId], map: "idx_deals_org_account_active")
  @@index([organizationId, status, expectedCloseDate], map: "idx_deals_org_status_close_date")
  @@map("deals")
  @@schema("customer")
}

enum ProjectStatus {
  planning
  active
  on_hold
  completed
  cancelled
  archived

  @@schema("projects")
}

enum ProjectPriority {
  low
  medium
  high
  critical

  @@schema("projects")
}

enum TaskStatus {
  backlog
  todo
  in_progress
  in_review
  blocked
  done
  cancelled

  @@schema("projects")
}

model Project {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String          @map("organization_id") @db.Uuid
  workspaceId     String?         @map("workspace_id") @db.Uuid
  code            String
  name            String
  description     String?
  status          ProjectStatus   @default(planning)
  priority        ProjectPriority @default(medium)
  startDate       DateTime?       @map("start_date") @db.Date
  targetEndDate   DateTime?       @map("target_end_date") @db.Date
  progressPercent Decimal         @default(0) @map("progress_percent") @db.Decimal(5, 2)
  metadata        Json            @default("{}")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy       String?         @map("created_by") @db.Uuid
  updatedBy       String?         @map("updated_by") @db.Uuid
  deletedAt       DateTime?       @map("deleted_at") @db.Timestamptz(6)
  version         Int             @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  workspace    Workspace?   @relation(fields: [workspaceId], references: [id])
  tasks        ProjectTask[]

  @@index([organizationId, status], map: "idx_projects_org_status")
  @@map("projects")
  @@schema("projects")
}

model ProjectTask {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  projectId      String          @map("project_id") @db.Uuid
  parentTaskId   String?         @map("parent_task_id") @db.Uuid
  assigneeId     String?         @map("assignee_id") @db.Uuid
  title          String
  description    String?
  status         TaskStatus      @default(todo)
  priority       ProjectPriority @default(medium)
  dueDate        DateTime?       @map("due_date") @db.Timestamptz(6)
  completedAt    DateTime?       @map("completed_at") @db.Timestamptz(6)
  metadata       Json            @default("{}")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdBy      String?         @map("created_by") @db.Uuid
  updatedBy      String?         @map("updated_by") @db.Uuid
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz(6)
  version        Int             @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  project      Project      @relation(fields: [projectId], references: [id])
  parentTask   ProjectTask? @relation("ProjectTaskHierarchy", fields: [parentTaskId], references: [id])
  childTasks   ProjectTask[] @relation("ProjectTaskHierarchy")
  assignee     User?        @relation("ProjectTaskAssignee", fields: [assigneeId], references: [id])

  @@index([organizationId, projectId], map: "idx_tasks_project")
  @@index([organizationId, assigneeId, status], map: "idx_tasks_assignee")
  @@map("tasks")
  @@schema("projects")
}

enum LedgerAccountType {
  asset
  liability
  equity
  revenue
  expense

  @@schema("ledger")
}

enum NormalBalance {
  debit
  credit

  @@schema("ledger")
}

enum JournalEntryStatus {
  draft
  posted
  reversed

  @@schema("ledger")
}

model ChartOfAccount {
  id              String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String            @map("organization_id") @db.Uuid
  parentAccountId String?           @map("parent_account_id") @db.Uuid
  code            String
  name            String
  description     String?
  accountType     LedgerAccountType @map("account_type")
  normalBalance   NormalBalance     @map("normal_balance")
  isActive        Boolean           @default(true) @map("is_active")
  isSystem        Boolean           @default(false) @map("is_system")
  currencyCode    String            @default("USD") @map("currency_code") @db.Char(3)
  metadata        Json              @default("{}")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)
  createdBy       String?           @map("created_by") @db.Uuid
  updatedBy       String?           @map("updated_by") @db.Uuid
  version         Int               @default(1)

  organization  Organization   @relation(fields: [organizationId], references: [id])
  parentAccount ChartOfAccount?  @relation("CoaHierarchy", fields: [parentAccountId], references: [id])
  childAccounts ChartOfAccount[] @relation("CoaHierarchy")
  journalLines  JournalLine[]

  @@unique([organizationId, code], map: "uq_coa_org_code_active")
  @@index([organizationId], map: "idx_coa_organization_id")
  @@map("chart_of_accounts")
  @@schema("ledger")
}

model JournalEntry {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String             @map("organization_id") @db.Uuid
  entryNumber    String             @map("entry_number")
  entryDate      DateTime           @default(now()) @map("entry_date") @db.Date
  status         JournalEntryStatus @default(draft)
  description    String
  currencyCode   String             @default("USD") @map("currency_code") @db.Char(3)
  totalDebit     Decimal            @default(0) @map("total_debit") @db.Decimal(19, 4)
  totalCredit    Decimal            @default(0) @map("total_credit") @db.Decimal(19, 4)
  postedBy       String?            @map("posted_by") @db.Uuid
  postedAt       DateTime?          @map("posted_at") @db.Timestamptz(6)
  metadata       Json               @default("{}")
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?          @map("deleted_at") @db.Timestamptz(6)
  createdBy      String?            @map("created_by") @db.Uuid
  updatedBy      String?            @map("updated_by") @db.Uuid
  version        Int                @default(1)

  organization Organization @relation(fields: [organizationId], references: [id])
  postedByUser User?        @relation("JournalEntryPostedBy", fields: [postedBy], references: [id])
  lines        JournalLine[]

  @@unique([organizationId, entryNumber], map: "uq_journal_entries_org_number")
  @@index([organizationId], map: "idx_journal_entries_organization_id")
  @@map("journal_entries")
  @@schema("ledger")
}

model JournalLine {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  journalEntryId String    @map("journal_entry_id") @db.Uuid
  accountId      String    @map("account_id") @db.Uuid
  lineNumber     Int       @map("line_number")
  description    String?
  debitAmount    Decimal   @default(0) @map("debit_amount") @db.Decimal(19, 4)
  creditAmount   Decimal   @default(0) @map("credit_amount") @db.Decimal(19, 4)
  metadata       Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)
  version        Int       @default(1)

  organization Organization   @relation(fields: [organizationId], references: [id])
  journalEntry JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      ChartOfAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId], map: "idx_journal_lines_entry")
  @@map("journal_lines")
  @@schema("ledger")
}
