  payload          Json
  metadata         Json                  @default("{}")
  failureReason    String                @map("failure_reason")
  failureCount     Int                   @default(1) @map("failure_count")
  firstFailedAt    DateTime              @map("first_failed_at") @db.Timestamptz(6)
  lastFailedAt     DateTime              @default(now()) @map("last_failed_at") @db.Timestamptz(6)
  resolvedAt       DateTime?             @map("resolved_at") @db.Timestamptz(6)
  resolvedBy       String?               @map("resolved_by") @db.Uuid
  resolutionAction DeadLetterResolution? @map("resolution_action")
  createdAt        DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([lastFailedAt(sort: Desc)], map: "idx_event_dead_letter_unresolved")
  @@index([tenantId, eventType], map: "idx_event_dead_letter_tenant")
  @@map("event_dead_letter")
  @@schema("atlas_audit")
}

model EntityVersion {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  entityType    String   @map("entity_type")
  entityId      String   @map("entity_id") @db.Uuid
  versionNumber Int      @map("version_number")
  validFrom     DateTime @default(now()) @map("valid_from") @db.Timestamptz(6)
  validTo       DateTime @default(dbgenerated("'infinity'::timestamptz")) @map("valid_to") @db.Timestamptz(6)
  state         Json
  changeReason  String?  @map("change_reason")
  changedBy     String?  @map("changed_by") @db.Uuid
  changedAt     DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)
  isCurrent     Boolean  @default(true) @map("is_current")

  @@index([tenantId, entityType, entityId, validFrom(sort: Desc)], map: "idx_entity_versions_temporal")
  @@index([tenantId, entityType, entityId, validFrom, validTo], map: "idx_entity_versions_as_of")
  @@map("entity_versions")
  @@schema("atlas_audit")
}

