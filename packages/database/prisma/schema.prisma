  previousState  Json?          @map("previous_state")
  newState       Json?          @map("new_state")
  metadata       Json           @default("{}")
  correlationId  String?        @map("correlation_id")
  requestId      String?        @map("request_id")
  ipAddress      String?        @map("ip_address")
  userAgent      String?        @map("user_agent")
  occurredAt     DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(6)

  @@index([tenantId, entityType, entityId, occurredAt(sort: Desc)], map: "idx_audit_log_entries_tenant_entity")
  @@index([tenantId, actorId, occurredAt(sort: Desc)], map: "idx_audit_log_entries_actor")
  @@index([correlationId], map: "idx_audit_log_entries_correlation")
  @@index([occurredAt(sort: Desc)], map: "idx_audit_log_entries_occurred")
  @@map("audit_log_entries")
  @@schema("atlas_audit")
}

model DomainEvent {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String?        @map("tenant_id") @db.Uuid
