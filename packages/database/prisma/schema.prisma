  causationId    String?        @map("causation_id")
  actorId        String?        @map("actor_id") @db.Uuid
  actorType      AuditActorType @default(system) @map("actor_type")
  occurredAt     DateTime       @default(now()) @map("occurred_at") @db.Timestamptz(6)
  publishedAt    DateTime       @default(now()) @map("published_at") @db.Timestamptz(6)
  sequenceNumber BigInt         @map("sequence_number")

  @@index([tenantId, aggregateType, aggregateId, occurredAt(sort: Desc)], map: "idx_domain_events_tenant_aggregate")
  @@index([eventType, occurredAt(sort: Desc)], map: "idx_domain_events_type")
  @@map("domain_events")
  @@schema("atlas_audit")
}

model EventOutbox {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?   @map("tenant_id") @db.Uuid
  aggregateType   String    @map("aggregate_type")
  aggregateId     String    @map("aggregate_id") @db.Uuid
  eventType       String    @map("event_type")
