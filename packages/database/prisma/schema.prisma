// Audit & Events bounded context — audit log, domain events, outbox, temporal versions
// Schema: atlas_audit
// See: docs/database/20-audit-events.md

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ACCESS
  EXPORT
  PERMISSION_CHANGE

  @@schema("atlas_audit")
}

enum AuditActorType {
  user
  system
  api_key
  agent
  workflow
  platform_admin

  @@schema("atlas_audit")
}

enum DeadLetterSource {
  event_outbox
  domain_events
  webhook_delivery

  @@schema("atlas_audit")
}

enum DeadLetterResolution {
  replayed
  discarded
  manual_fix

  @@schema("atlas_audit")
}

model AuditLogEntry {
  id             BigInt         @id @default(autoincrement())
  tenantId       String?        @map("tenant_id") @db.Uuid
  entityType     String         @map("entity_type")
  entityId       String         @map("entity_id") @db.Uuid
