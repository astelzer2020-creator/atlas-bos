  @@unique([fileId, granteeType, granteeId, permission], map: "uq_file_permissions_grantee")
  @@index([fileId], map: "idx_file_permissions_file_id")
  @@index([tenantId, granteeType, granteeId], map: "idx_file_permissions_grantee")
  @@map("file_permissions")
  @@schema("storage")
}

model StorageQuota {
