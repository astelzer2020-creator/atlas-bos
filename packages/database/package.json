{
  "name": "@atlas/database",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas BOS — Prisma client, tenant context, and database migrations",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "db"
  ],
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "prisma generate",
    "migrate": "node scripts/migrate-sql.mjs",
    "migrate:prisma": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "push": "prisma db push",
    "studio": "prisma studio",
    "test": "vitest run",
    "test:unit": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "prisma": "^6.19.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}