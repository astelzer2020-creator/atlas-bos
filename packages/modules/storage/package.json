{
  "name": "@atlas/module-storage",
  "version": "0.1.0",
  "private": true,
  "description": "Atlas BOS — Documents & Storage bounded context (files, folders, quotas, presigned uploads)",
  "type": "module",
  "main": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "types": "./dist/module.d.ts",
      "import": "./dist/module.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@atlas/database": "workspace:*",
    "@atlas/platform": "workspace:*",
    "@atlas/shared-kernel": "workspace:*",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}