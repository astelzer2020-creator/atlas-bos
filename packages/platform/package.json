{
  "name": "@atlas/platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/env.d.ts",
      "import": "./dist/config/env.js"
    },
    "./logging": {
      "types": "./dist/logging/logger.d.ts",
      "import": "./dist/logging/logger.js"
    },
    "./errors": {
      "types": "./dist/errors/http-errors.d.ts",
      "import": "./dist/errors/http-errors.js"
    },
    "./metrics": {
      "types": "./dist/metrics/metrics.d.ts",
      "import": "./dist/metrics/metrics.js"
    },
    "./metrics/prometheus": {
      "types": "./dist/metrics/prometheus.d.ts",
      "import": "./dist/metrics/prometheus.js"
    },
    "./security": {
      "types": "./dist/security/jwt-service.d.ts",
      "import": "./dist/security/jwt-service.js"
    },
    "./tenant": {
      "types": "./dist/tenant/tenant-context.d.ts",
      "import": "./dist/tenant/tenant-context.js"
    },
    "./validation": {
      "types": "./dist/validation/zod-helpers.d.ts",
      "import": "./dist/validation/zod-helpers.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@atlas/shared-kernel": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "fastify": "^5.2.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}