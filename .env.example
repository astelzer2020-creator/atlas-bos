# Database
DATABASE_URL="postgresql://atlas:atlas_dev_password@localhost:5432/atlas?schema=public"

# API
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=3001
API_BASE_URL=http://localhost:3001

# Auth
JWT_SECRET=change-me-in-production-use-64-char-random-string-minimum-length-required
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
BCRYPT_ROUNDS=12

# Redis
REDIS_URL=redis://localhost:6379

# Kafka (Redpanda locally)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=atlas

# Worker
# WORKER_ID defaults to hostname when unset
WORKER_PORT=3002
WORKER_HOST=0.0.0.0

# Observability
PROMETHEUS_ENABLED=false

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# CORS
CORS_ORIGINS=http://localhost:3000

# Email (optional — log transport used when SMTP_HOST is unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@atlas.local
SMTP_SECURE=false
SMTP_HTTP_RELAY_URL=

# Storage (local dev defaults)
ATLAS_STORAGE_PROVIDER=local
ATLAS_STORAGE_LOCAL_ROOT=./.atlas-storage
ATLAS_STORAGE_LOCAL_BASE_URL=http://localhost:3001/v1/storage/local
ATLAS_STORAGE_KMS_KEY_ID=local-dev-key