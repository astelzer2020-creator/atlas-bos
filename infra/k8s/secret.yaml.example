# Copy to secret.yaml and replace placeholder values before applying.
# Do NOT commit secret.yaml to version control.
apiVersion: v1
kind: Secret
metadata:
  name: atlas-secrets
  namespace: atlas
  labels:
    app.kubernetes.io/name: atlas
    app.kubernetes.io/part-of: atlas-bos
type: Opaque
stringData:
  JWT_SECRET: change-me-use-64-char-random-string-minimum-length-required
  POSTGRES_PASSWORD: change-me-strong-postgres-password
  DATABASE_URL: postgresql://atlas:change-me-strong-postgres-password@postgres:5432/atlas?schema=public
  GRAFANA_ADMIN_PASSWORD: change-me-grafana-admin-password