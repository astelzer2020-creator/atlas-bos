{
  "name": "@atlas/web",
  "version": "1.0.0",
  "private": true,
  "description": "Atlas BOS — Next.js web application",
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 3000",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
